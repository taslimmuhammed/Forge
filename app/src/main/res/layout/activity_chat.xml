<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:background="#0F0F1A">

    <!-- Toolbar -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fitsSystemWindows="true"
        android:background="#161625"
        app:elevation="4dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:titleTextColor="#FFFFFF">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="56dp">

                <!-- Title set programmatically -->
                <TextView
                    android:id="@+id/tvProjectTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Project"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"/>

                <TextView
                    android:id="@+id/tvPackageName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="com.example.app"
                    android:textSize="11sp"
                    android:textColor="#7B7B9A"/>
            </LinearLayout>

        </androidx.appcompat.widget.Toolbar>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- Run row moved below toolbar to avoid notch overlap -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#161625"
        android:gravity="end"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="6dp"
        android:paddingBottom="8dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRun"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="▶ Run"
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            app:backgroundTint="#22C55E"
            app:cornerRadius="8dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp" />
    </LinearLayout>

    <!-- Status bar -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1E1E35"
        android:padding="8dp"
        android:paddingStart="16dp"
        android:textSize="12sp"
        android:textColor="#A0AEC0"
        android:singleLine="true"
        android:ellipsize="end"
        android:visibility="gone"/>

    <!-- Progress bar -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
        android:indeterminate="true"
        android:progressTint="#6C63FF"
        android:visibility="gone"/>

    <!-- Chat Messages -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMessages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        android:clipToPadding="false"
        android:scrollbars="none"/>

    <!-- Build Log Sheet (collapsible) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/buildLogSheet"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        app:cardBackgroundColor="#0D1117"
        app:cardCornerRadius="0dp"
        android:visibility="gone">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <TextView
                android:id="@+id/tvBuildLog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:textSize="11sp"
                android:textColor="#58A6FF"
                android:fontFamily="monospace"/>
        </ScrollView>
    </com.google.android.material.card.MaterialCardView>

    <!-- Input Area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:background="#161625"
        android:gravity="bottom">

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Describe what you want to build..."
            app:hintTextColor="#7B7B9A"
            app:boxBackgroundColor="#1E1E35"
            app:boxStrokeColor="#2D2D52"
            app:boxStrokeWidth="1dp"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:maxLines="4"
                android:inputType="textMultiLine|textCapSentences"
                android:imeOptions="flagNoEnterAction"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"/>
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSend"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:padding="0dp"
            app:icon="@android:drawable/ic_menu_send"
            app:iconTint="#FFFFFF"
            app:iconSize="20dp"
            app:backgroundTint="#6C63FF"
            app:cornerRadius="12dp"/>

    </LinearLayout>

</LinearLayout>
