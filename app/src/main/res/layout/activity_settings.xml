<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0F0F1A">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#161625">
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"/>
    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- API Key Section -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="#161625"
                app:cardCornerRadius="12dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔑 Anthropic API Key"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:layout_marginBottom="8dp"/>
                    <TextView
                        android:id="@+id/tvApiKeyStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Checking..."
                        android:textSize="13sp"
                        android:textColor="#A0AEC0"
                        android:layout_marginBottom="12dp"/>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnChangeApiKey"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Change Key"
                            android:textSize="12sp"
                            app:backgroundTint="#6C63FF"
                            android:layout_marginEnd="6dp"/>
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnClearApiKey"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Clear Key"
                            android:textSize="12sp"
                            app:backgroundTint="#F44336"
                            android:layout_marginEnd="6dp"/>
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnGetApiKey"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Get Key ↗"
                            android:textSize="12sp"
                            app:backgroundTint="#1E1E35"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Build Tools Section -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="#161625"
                app:cardCornerRadius="12dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔨 Build Tools"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:layout_marginBottom="8dp"/>
                    <TextView
                        android:id="@+id/tvInstallPermission"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Checking permissions..."
                        android:textSize="13sp"
                        android:textColor="#A0AEC0"
                        android:layout_marginBottom="4dp"/>
                    <TextView
                        android:id="@+id/tvTermuxStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:textColor="#A0AEC0"
                        android:layout_marginBottom="12dp"/>
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnGrantInstallPermission"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Grant Install Permission"
                        app:backgroundTint="#22C55E"
                        android:layout_marginBottom="8dp"/>
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnTermuxGuide"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Setup Termux Build Tools"
                        app:backgroundTint="#1E1E35"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- About Section -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#161625"
                app:cardCornerRadius="12dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ℹ️ About"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:layout_marginBottom="8dp"/>
                    <TextView
                        android:id="@+id/tvVersion"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:textColor="#A0AEC0"
                        android:layout_marginBottom="12dp"/>
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnViewGithub"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="View on GitHub ↗"
                        app:backgroundTint="#1E1E35"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>
</LinearLayout>